{
  "$defs": {
    "BuySell": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "BuySell",
      "type": "string"
    },
    "Trade": {
      "additionalProperties": false,
      "description": "Aggregated trade (one or more fills for the same order).",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "assetClass": {
          "$ref": "#/$defs/AssetClass"
        },
        "side": {
          "$ref": "#/$defs/BuySell"
        },
        "orderType": {
          "anyOf": [
            {
              "$ref": "#/$defs/OrderType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "price": {
          "type": "number"
        },
        "volume": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "fee": {
          "type": "number"
        },
        "fillCount": {
          "type": "integer"
        },
        "execIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timestamp": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "raw": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "orderId",
        "symbol",
        "assetClass",
        "side",
        "price",
        "volume",
        "cost",
        "fee",
        "fillCount",
        "execIds",
        "timestamp",
        "source",
        "raw"
      ],
      "title": "Trade",
      "type": "object"
    },
    "RunPollResponse": {
      "additionalProperties": false,
      "properties": {
        "trades": {
          "items": {
            "$ref": "#/$defs/Trade"
          },
          "type": "array"
        }
      },
      "required": [
        "trades"
      ],
      "title": "RunPollResponse",
      "type": "object"
    },
    "HealthResponse": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "title": "HealthResponse",
      "type": "object"
    },
    "AssetClass": {
      "enum": [
        "crypto",
        "equity",
        "forex",
        "future",
        "option",
        "other"
      ],
      "type": "string"
    },
    "OrderType": {
      "enum": [
        "limit",
        "market",
        "stop",
        "stop_limit",
        "trailing_stop"
      ],
      "type": "string"
    },
    "Source": {
      "enum": [
        "commissionReportEvent",
        "execDetailsEvent",
        "flex"
      ],
      "type": "string"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/RunPollResponse"
    },
    {
      "$ref": "#/$defs/HealthResponse"
    }
  ]
}
